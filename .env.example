# APO-EMS Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env — only .env.example

# Server port (Express backend)
PORT=3001

# If integrating with an external AI model API, proxy through server/index.ts
# GEMINI_API_KEY=your_key_here

# SCADA connection (production only)
# MODBUS_HOST=192.168.1.100
# MODBUS_PORT=502
